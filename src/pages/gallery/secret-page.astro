---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Secret Page">
  <div class="content">
    <h1>Efecto Visor Circular</h1>
    <p>
      Mueve el ratón para explorar el contenido a través del círculo. Puedes
      cambiar el tamaño del visor con los botones de abajo.
    </p>

    <div class="controls">
      <button id="small">Visor Pequeño</button>
      <button id="medium">Visor Mediano</button>
      <button id="large">Visor Grande</button>
      <button id="toggle">Alternar Efecto</button>
    </div>
  </div>

  <div class="overlay"></div>
  <div class="spotlight"></div>

  <div class="instructions">
    Mueve el ratón para explorar el contenido oculto
  </div>
</Layout>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const spotlight = document.querySelector(".spotlight");
    const overlay = document.querySelector(".overlay");
    const toggleButton = document.getElementById("toggle");
    let isEffectActive = true;

    // Actualizar la posición del círculo según el movimiento del ratón
    document.addEventListener("mousemove", function (e) {
      if (!isEffectActive) return;

      const x = e.clientX;
      const y = e.clientY;

      spotlight.style.left = x - spotlight.offsetWidth / 2 + "px";
      spotlight.style.top = y - spotlight.offsetHeight / 2 + "px";
    });

    // Cambiar tamaño del visor
    document.getElementById("small").addEventListener("click", function () {
      spotlight.style.width = "100px";
      spotlight.style.height = "100px";
    });

    document.getElementById("medium").addEventListener("click", function () {
      spotlight.style.width = "150px";
      spotlight.style.height = "150px";
    });

    document.getElementById("large").addEventListener("click", function () {
      spotlight.style.width = "200px";
      spotlight.style.height = "200px";
    });

    // Alternar efecto
    toggleButton.addEventListener("click", function () {
      isEffectActive = !isEffectActive;

      if (isEffectActive) {
        overlay.style.display = "block";
        spotlight.style.display = "block";
        document.body.style.cursor = "none";
        toggleButton.textContent = "Desactivar Efecto";
      } else {
        overlay.style.display = "none";
        spotlight.style.display = "none";
        document.body.style.cursor = "default";
        toggleButton.textContent = "Activar Efecto";
      }
    });
  });
</script>
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #6e8efb, #a777e3);
    color: #333;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    cursor: none;
  }

  .content {
    max-width: 800px;
    padding: 2rem;
    text-align: center;
    z-index: 1;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #fff;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  p {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: #f0f0f0;
  }

  /* .overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.55);
    pointer-events: none;
    z-index: 2;
  } */

  .spotlight {
    position: absolute;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: transparent;
    box-shadow: 0 0 0 9999px rgba(0, 0, 0, 1);
    pointer-events: none;
    z-index: 3;
    transition: transform 0.1s ease;
  }

  .instructions {
    position: fixed;
    bottom: 20px;
    left: 0;
    width: 100%;
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    z-index: 4;
  }

  .controls {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  button {
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  button:hover {
    background: rgba(255, 255, 255, 0.3);
  }
</style>
